    function InputAcessorio(data){
        let acessorio =  0
        document.getElementById('cab-acess').value = data[acessorio]
    }

    function salva_acess(){
        let selct_acesso = document.getElementById('acesso').selectedOptions[0].id
        let acess = document.getElementById('cab-acess').value;
        let data_dict ={};

        let lista_ids_cab = ['cab-acess'];
        let list_campo_tamanh = [acess.length]

        if(acess.length <= 11 ){
             data_dict = {
