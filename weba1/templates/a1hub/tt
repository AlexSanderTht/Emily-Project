    function salva_terra_neu(){
        let cabo_terra5 = document.getElementById('cab_terra_5').value
        let cabo_terra = document.getElementById('cab_terra').value
        let cabo_neutro_5 = document.getElementById('cabo_neutro').value
        let tipo_cabo_neutro = document.getElementById('cabo_neutro_3').value

        let listids_terra_neutro = ['cab_terra_5', 'cab_terra', 'tipo_terra', 'tipo_veias_terra' , 'cabo_neutro' , 'cabo_neutro_3', 'tipo_neutro', 'tipo_veias_neutro'];
        let list_tamnh_camp_neu = [cabo_terra5.length , cabo_terra.length ,  cabo_neutro_5.length, tipo_cabo_neutro.length]

        if( cabo_terra5.length <= 5  && cabo_neutro_5.length <= 5 && tipo_cabo_neutro.length <= 3 && cabo_terra.length <= 3){
            document.getElementById('certo').innerText=''
