    function PostDataAcessorios(){
        let id_caboacesorio = document.getElementById('acesso').selectedOptions[0].id
        const csrftoken = document.getElementsByName('csrfmiddlewaretoken')[0].value
        $.ajax({
            url:"/app/eletrica/a1pro/cabo_acessorio",
