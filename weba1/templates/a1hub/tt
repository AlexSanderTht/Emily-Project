    function salva_terminais(){
        let ponta1_tipo_curto = document.getElementById('tipo_ponta_curto').value
        let ponta1_tipo_coce_longo = document.getElementById('tipo_coce_longo').value

        let list_ids_terminais = [ 'tipo_ponta_curto' , 'tipo_coce_longo' , 'tipo_curto_secao', 'tipo_jt_curto', 'tipo_cr_curto', 'tipo_1_curto', 'tipo_curto_coce', 'tipo_longo',
                                   'tipo_jt_longo', 'tipo_coce_longo_1', 'tipo_1_longo', 'para_potencia' , 'tipo_secao', 'cor_secao']
        let terminais_tamanho_stri = [ponta1_tipo_curto.length , ponta1_tipo_coce_longo.length ]
        if(ponta1_tipo_curto.length <= 4 && ponta1_tipo_coce_longo.length <=4 ){
            document.getElementById('certo').innerText=''
            document.getElementById('certo').innerText='Campos cadastrados com sucesso!'
            $('#modal_mensagem_certo').modal('show')
        }
        else{
            for( let t in list_ids_terminais){CampoInvalid(list_ids_terminais[t], terminais_tamanho_stri[t])}
            document.getElementById('error').innerText=''
            document.getElementById('error').innerText='Favor preencher corretamente todos os campos!'
            $('#modal_mensagem_erro').modal('show')
        }
    }

    // ---funcao valida formulario--- //
    function CampoInvalid(item,tamanho){
        let i = document.getElementById(item)
        if (tamanho > 10 || tamanho > 4 || tamanho > 5 || tamanho > 3) {
            console.log(tamanho)
            i.classList.add('is-invalid')
        }else{
            console.log(i)
            i.classList.remove('is-invalid')
            i.classList.add('is-valid')
        }
    }

</script>