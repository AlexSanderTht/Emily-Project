<script>
    async  function getDatainfo(id){
        await $.ajax({
            type: "GET",
            url: "A1Config_a1mat"+id+ "/",
            dataType:'json',
            data: {},
            success: function (data){
                let datas_returned = data['func']
                document.getElementById('funcao_os').selectedOptions[0].id;
                document.getElementById('cabo_unipolar').value = datas_returned['cabo_unipolar']
                document.getElementById('cabo_bipolar').value = datas_returned['cabo_bipolar']
                document.getElementById('cabo_tripolar').value = datas_returned['cabo_tripolar']
                document.getElementById('cabo_tetrapolar').value = datas_returned['cabo_tetrapolar']
                document.getElementById('cabo_pentapolar').value = datas_returned['cabo_pentapolar']
                document.getElementById('cabo_shield').value = datas_returned['cabo_shield']

                let data_return_sinais = data['cod']
                document.getElementById('sinais').selectedOptions[0].id;
                document.getElementById('cab-sin').value = data_return_sinais['cab-sin']

                let data_return_acessorios = data['acess']
                document.getElementById('acesso').selectedOptions[0].id;
                document.getElementById('cab-acess').value = data_return_acessorios['cab-acess']

            }
        })
    }

    function PostDatainfo(){
        let id_cabos_alim =  document.getElementById('funcao_os').selectedOptions[0].id
        const csrftoken = document.getElementsByName('csrfmiddlewaretoken')[0].value
        $.ajax({
            url: "/app/eletrica/a1pro/A1Config_a1mat/",
            type: "POST",
            headers:{'X-CSRFToken': csrftoken},
            dataType:"json",
            data:{'Consulta':id_cabos_alim},
            success: function(data){
                InputCod(data['codigos_funcao'])
            },
            failure: function () {
                  alert('Algo deu errado! verifique e tente novamente.')
            }
        });
    }

    function InputCod(data){
        let unipolar = 0
        let bipolar = 1
        let tripolar = 2
        let tetrapolar = 3
        let pentapolar = 4
        let shield = 5
        document.getElementById('cabo_unipolar').value = data[0][unipolar]
        document.getElementById('cabo_bipolar').value = data[0][bipolar]
        document.getElementById('cabo_tripolar').value = data[0][tripolar]
        document.getElementById('cabo_tetrapolar').value = data[0][tetrapolar]
        document.getElementById('cabo_pentapolar').value = data[0][pentapolar]
        document.getElementById('cabo_shield').value = data[0][shield]
    }

    function salva_cod(){
        let funcao = document.getElementById('funcao_os').selectedOptions[0].id
        let unipolar = document.getElementById('cabo_unipolar').value;
        let bipolar = document.getElementById('cabo_bipolar').value;
        let tripolar = document.getElementById('cabo_tripolar').value;
        let tetrapolar = document.getElementById('cabo_tetrapolar').value;
        let pentapolar = document.getElementById('cabo_pentapolar').value;
        let shield = document.getElementById('cabo_shield').value;
        let data_dict = {};

        let list_ids = ['cabo_unipolar', 'cabo_bipolar', 'cabo_tripolar', 'cabo_tetrapolar', 'cabo_pentapolar', 'cabo_shield' ];
        let list_campos_tamanho = [unipolar.length, bipolar.length, tripolar.length, tetrapolar.length, pentapolar.length, shield.length ]

        if (unipolar.length <= 10 && bipolar.length <= 10 && tripolar.length <= 10 && tetrapolar.length <= 10 && pentapolar.length <= 10 &&  shield.length <= 10){
            data_dict = {
                'funcaoos' : funcao,
                'cabounipolar': unipolar,
                'cabobipolar': bipolar,
                'cabotripolar': tripolar,
                'cabotetrapolar': tetrapolar,
                'cabo_pentapolar': pentapolar,
                'caboshield': shield
            }
             enviaform(data_dict)
             document.getElementById('error').innerText = ''
             document.getElementById('certo').innerText= 'Campos preenchidos com sucesso! '
             $('#modal_mensagem_certo').modal('show')
        }else {
            for (let i in list_ids) {
                CampoInvalid(list_ids[i], list_campos_tamanho[i])
                document.getElementById('error').innerText = ''
                document.getElementById('error').innerText = 'Favor preencher corretamente todos os campos! '
                $('#modal_mensagem_erro').modal('show')
            }

        }
    }
    function enviaform(data_dict){
         const csrftoken = document.getElementsByName('csrfmiddlewaretoken')[0].value
         $.ajax({
             url: "/app/eletrica/a1pro/Conf_Alim/",
             type:"POST",
             headers: {'X-CSRFToken': csrftoken},
             dataType: "json",
             data:{'NewCadastro': JSON.stringify(data_dict)},
             success: function (data){
             },
             failure: function() {
                 alert('Algo deu errado.')
             }
         });
    }


    function PostDataSin(){
        let id_cabosinais = document.getElementById('sinais').selectedOptions[0].id
        const csrftoken = document.getElementsByName('csrfmiddlewaretoken')[0].value
        $.ajax({
            url:"/app/eletrica/a1pro/Cabo_sinais/",
            type:"POST",
